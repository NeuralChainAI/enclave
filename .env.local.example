# Copy to .env.local and adjust for your environment.
#
# Onyx API base, reached server-side via the Next.js /api/onyx/* proxy.
# Local dev points straight at api_server (published on :8080 by the Enclave
# compose override) — api_server serves routes WITHOUT the /api prefix.
# When the Onyx web frontend + nginx are healthy, switch to http://localhost:3001/api.
ONYX_API_URL=http://localhost:8080

# Only needed when Onyx runs with AUTH_TYPE != disabled (showcase/prod posture).
# ONYX_API_KEY=

# Admin API key for deterministic Research retrieval (POST /admin/search).
# /admin/* requires an ADMIN-role key even when AUTH_TYPE=disabled.
# Minted + written to .env.local automatically by deploy/seed/seed.sh.
ONYX_ADMIN_API_KEY=

# How many passages to retrieve per Research question (default 5).
# ONYX_RESEARCH_TOP_K=5
